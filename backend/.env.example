# ─── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── IBM Cloud Authentication ──────────────────────────────────────────────────
# Generate at: https://cloud.ibm.com/iam/apikeys
IBM_API_KEY=your_ibm_api_key_here

# ─── IBM Cloud Region ──────────────────────────────────────────────────────────
# e.g.  us-south | eu-gb | au-syd | jp-tok
IBM_REGION=us-south

# ─── IBM AutoAI Deployment Endpoint ───────────────────────────────────────────
# Full scoring URL from your Watson ML deployment:
# https://<region>.ml.cloud.ibm.com/ml/v4/deployments/<deployment_id>/predictions?version=2021-05-01
IBM_DEPLOYMENT_ENDPOINT=https://us-south.ml.cloud.ibm.com/ml/v4/deployments/YOUR_DEPLOYMENT_ID/predictions?version=2021-05-01

# ─── IBM Project / Space ID ────────────────────────────────────────────────────
IBM_PROJECT_ID=your_ibm_project_id_here

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
